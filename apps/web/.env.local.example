# Copy to .env.local and fill in values from your Supabase project.
# Find these at https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: signaling worker URL for the viewer page.
# In dev, set to ws://localhost:8787 if running wrangler locally.
NEXT_PUBLIC_SIGNALING_URL=wss://oneclickcast-signaling.workers.dev
